# --- hotkey ---
# evdev key name to hold. Single key or "MOD+KEY".
hotkey = KEY_RIGHTCTRL

# --- engine ---
# Which transcriber runs.
#
#   openai     upload each utterance to OpenAI. Needs an api_key below.
#              About 99 languages.
#   parakeet   NVIDIA Parakeet TDT 0.6B v3, decoded on this machine. No key,
#              no bill, no network, and nothing spoken leaves the computer.
#              Costs about 1 GB of memory while running, and covers 25
#              European languages. Only in builds made with WITH_PARAKEET=1;
#              run ./install-parakeet.sh to get one.
engine = openai

# --- parakeet ---
# Where the model files live. Empty = where install-parakeet.sh puts them,
# /usr/local/share/scribe/models/parakeet-tdt-0.6b-v3-int8.
model_dir =
# Decode threads. 0 = 4, which keeps a 0.6B model busy without taking the
# machine over. Raise it if transcripts lag; lower it on a small laptop.
threads = 0

# --- live preview ---
# Off by default. Type words into the focused window as you speak them, rather
# than waiting for the whole utterance. What appears while you hold the key
# comes from a small streaming model and is a guess; when you let go, scribe
# backspaces over it and types what Parakeet actually heard. The transcript you
# keep is the same either way -- this only changes when you see it.
#
# Worth knowing before you turn it on: the preview has no punctuation and gets
# words wrong, and you watch it correct itself in your own document. Some people
# like seeing the machine keep up; others find it distracting. Try it before
# leaving it on.
#
# It runs only where all four hold, and says in the log which one failed:
#   - a hotkey that is not a modifier. This one bites: the preview types while
#     you are still holding the key, so a hotkey of KEY_RIGHTCTRL (the default)
#     would send Ctrl+V, Ctrl+W, Ctrl+Q into whatever window has focus instead
#     of letters. Pick a spare key -- KEY_F13, KEY_SCROLLLOCK, or anything you
#     do not otherwise type.
#   - engine = parakeet. There is no live path to a network endpoint.
#   - an injection backend that can erase, so wlr-vk or uinput. The clipboard
#     backend pastes rather than types and cannot take anything back.
#   - the streaming model installed, which install-parakeet.sh fetches.
# Anywhere else scribe falls back to typing the transcript in one go.
live = off
# Where the streaming model lives. Empty = where install-parakeet.sh puts it,
# /usr/local/share/scribe/models/streaming-zipformer-en.
live_model_dir =

# --- cleanup ---
# Off by default. Pass each transcript through a local instruction model that
# fixes what speech does and writing does not: it drops "um" and "uh", resolves
# a spoken correction, adds punctuation and capitals. It changes nothing else --
# the words stay yours.
#
#   you say:   "Hey, let's meet at 5pm on Monday, uh, no 5pm on tuesday"
#   you get:   "Hey, let's meet at 5pm on Tuesday."
#
# The raw transcript appears first, then scribe backspaces over it and types the
# corrected one when the model answers -- the same swap the live preview uses, so
# it needs a backend that can erase (wlr-vk or uinput, not clipboard). If the
# model does not answer within cleanup_timeout_ms, the raw transcript stands.
#
# Local only. The endpoint has to be on this machine: scribe refuses to start if
# cleanup_endpoint_url points anywhere else, so turning this on cannot quietly
# start uploading everything you dictate. Any OpenAI-compatible chat server
# works; the default is Ollama's port. To get one running:
#   ollama serve
#   ollama pull qwen2.5:3b-instruct     # then set cleanup_model below
#
# One caveat worth knowing: if you move the caret or type during the moment
# between the raw text and the correction, the backspaces land in the wrong
# place. The timeout is short to keep that window small.
cleanup = off
cleanup_endpoint_url = http://localhost:11434/v1
cleanup_model =
cleanup_timeout_ms = 2500
# Words the model should spell correctly -- names, jargon, project terms -- one
# per line, '#' for comments. Empty = ~/.config/scribe/vocabulary.txt if it
# exists. A missing file is fine; it just means no extra vocabulary.
vocabulary_file =

# --- openai ---
# Required when engine = openai; ignored otherwise. scribe will not start
# without a key. Get one at https://platform.openai.com/api-keys
#
# $OPENAI_API_KEY in the environment overrides this line. Prefer that if you
# sync or back up your dotfiles -- this file is 0600, but a synced 0600 file
# is still a copy of your key on someone else's disk.
api_key      =

# whisper-1 | gpt-4o-transcribe | gpt-4o-mini-transcribe
model        = whisper-1

# Where the audio goes when engine = openai. Pointing it at an
# OpenAI-compatible server does work -- the request is the same multipart POST
# either way -- but it is not a tested path. For local transcription prefer
# engine = parakeet, which needs no server at all.
endpoint_url = https://api.openai.com/v1

# --- capture ---
# pulse/pipewire source name; empty = system default.
# List candidates with:  pactl list short sources
# A wrong source here is the #1 cause of hallucinated transcripts -- Whisper
# answers silence with caption boilerplate ("thanks for watching", stray
# copyright lines) rather than an empty string.
source =

# --- history ---
# on = append every transcript to a session file, which is what the menu's
# session list reads. Off by default: this is a verbatim record of everything
# spoken at the machine, so it is opt-in rather than something to discover
# later. Files are 0600 in a 0700 directory.
# Consecutive utterances share a file until 5 minutes of silence starts a new
# one; the file is named after the first thing said in it.
history = off
# empty = ~/.local/share/scribe/transcriptions (honours XDG_DATA_HOME)
history_dir =

# --- cues ---
# on = play a short tone so you can dictate without watching the screen: a
# rising pair when the hotkey goes down (listening), a falling pair when it
# comes up (captured), a low double beep when nothing usable came back. Needs
# paplay from pulseaudio-utils, which scribe already uses for capture.
audio_cues = on

# --- injection ---
# backend = auto | wlr-vk | uinput | clipboard
backend = auto
# XKB layout, used by the 'uinput' backend to work out which keycode and
# modifier level produces each character. It MUST match your active layout.
layout  = us
# Optional XKB variant, e.g. "intl" for us(intl), "nodeadkeys" for de.
variant =
# paste chord for the clipboard backend
paste_chord = ctrl+v          # terminals often need: ctrl+shift+v
